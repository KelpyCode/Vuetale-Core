{
  "extends": ["@vue/tsconfig/tsconfig.dom.json"],
  "include": [
    "env.d.ts",
    ".vuetale/vuetale.d.ts",
    "lib/**/*.ts",
    "lib/**/*.vue"
  ],
  "exclude": [
    "lib/**/__tests__/*"
  ],
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./lib/*"]
    }
  }
}